# Ignore environment variables
.env
.env.local
.env.*.local

# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class

# Ignore IDE files
.vscode/settings.json
.idea/

# Ignore log files
*.log
logs/

# Ignore database files
*.db
*.sqlite
*.sqlite3

# Ignore temporary files
*.tmp
*.temp

# Ignore backup files
*.bak
*.backup

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore sensitive config files
config.json
secrets.json
private_keys/

# Ignore node modules if any
node_modules/
