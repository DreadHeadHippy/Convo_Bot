# Environment Variables for Pedro Bot
# SECURITY: Never commit the actual .env file to git!
# This is just an example - copy to .env and add real values

# Discord Bot Token (Get from https://discord.com/developers/applications)
# Keep this secret! Never share or commit to git
BOT_TOKEN=your_discord_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Server Configuration
GUILD_ID=your_discord_server_id_here
DISCORD_GUILD_ID=your_discord_server_id_here

# Optional: Database URL if using database features
# DATABASE_URL=your_database_url_here

# Optional: Development/Production environment
# NODE_ENV=development
