{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Pedro Convo Bot",
			"type": "shell",
			"command": "python",
			"args": [
				"convo_interpreter/main.py",
				"pedro_convo/main.convo"
			],
			"group": "build",
			"isBackground": false,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"options": {
				"cwd": "${workspaceFolder}"
			}
		}
	]
}